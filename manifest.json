{
  "manifest_version": 3,
  "name": "Helper AI",
  "version": "1.0",
  "description": "Удобный ИИ агент для сжатия текста.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://router.huggingface.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon458.png"
  },
  "icons": {
    "16": "icon458.png",
    "48": "icon458.png",
    "128": "icon458.png"
  }
}
